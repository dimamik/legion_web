<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="csrf-token" content={get_csrf_token()} />

    <title>Legion Dashboard</title>
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='6' fill='%23073642'/><text x='50%25' y='50%25' dominant-baseline='central' text-anchor='middle' font-family='system-ui,sans-serif' font-weight='700' font-size='20' fill='%23eee8d5'>L</text></svg>"
    />

    <link rel="stylesheet" nonce={@csp_nonces.style} href={asset_path(@conn, :css)} />

    <script nonce={@csp_nonces.script} src={asset_path(@conn, :js)} defer>
    </script>
  </head>

  <body class="bg-sol-base3 text-sol-base01 min-h-screen antialiased">
    {@inner_content}
  </body>
</html>
